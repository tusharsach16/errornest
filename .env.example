# Postgres connection string (Neon, Supabase, or local)
DATABASE_URL="postgresql://user:password@localhost:5432/errornest"

# Session signing secret - generate with `openssl rand -base64 32`
AUTH_SECRET="replace-with-a-random-32-byte-string"

# Base URL for Auth.js callbacks
NEXTAUTH_URL="http://localhost:3000"

# Resend API key for critical-error email alerts (optional in dev)
RESEND_API_KEY=""
EMAIL_FROM="alerts@yourdomain.com"
