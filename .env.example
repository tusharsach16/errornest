# Postgres connection string (Neon, Supabase, or local)
DATABASE_URL="postgresql://user:password@localhost:5432/errornest"

# Session signing secret - generate with `openssl rand -base64 32`
AUTH_SECRET="replace-with-a-random-32-byte-string"

# Base URL for Auth.js callbacks
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Brevo API key for critical-error and invite email alerts (optional in dev)
# Note: EMAIL_FROM must be a verified sender configured in the Brevo dashboard (Settings > Senders)
BREVO_API_KEY=""
EMAIL_FROM="alerts@yourdomain.com"

# Slack Incoming Webhook URL for alerts (optional in dev)
# Configure this under Slack app > Incoming Webhooks
SLACK_WEBHOOK_URL=""
